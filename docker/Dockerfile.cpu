FROM emotion_robot:laptop

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

ENV BACKEND=cpu \
    OMP_NUM_THREADS=1 \
    OPENBLAS_NUM_THREADS=1 \
    MKL_NUM_THREADS=1 \
    NUMEXPR_NUM_THREADS=1 \
    MALLOC_ARENA_MAX=2 \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

WORKDIR /app

RUN set -eux; \
    mkdir -p /app /tmp/emotion_robot && \
    chmod 1777 /tmp/emotion_robot

CMD ["python3", "-c", "print('emotion_robot backend=cpu runtime ready')"]
